{
  "expo": {
    "name": "RespirAI-Mobile",
    "slug": "RespirAI-Mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "respiraimobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.lukas_x.RespirAIMobile"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "858e8cc7-3aee-48d1-af1e-831948492eb5"
      }
    }
  }
}
